@{
    ViewData["Title"] = "من نحن - قصتنا في التصميم والأصالة";
}

<main class="bg-surface min-h-screen">
    <!-- Hero Section -->
    <section class="relative h-[60vh] flex items-center justify-center overflow-hidden">
        <div class="absolute inset-0 -z-10">
            <div class="absolute inset-0 bg-black/20"></div>
            <img class="w-full h-full object-cover"
                 src="https://images.unsplash.com/photo-1497366216548-37526070297c?q=80&w=2000&auto=format&fit=crop"
                 alt="About Hero" />
        </div>
        <div class="container-center px-8 md:px-16 text-center">
            <h1 class="text-5xl md:text-7xl font-serif mb-6 leading-tight animate-fade-up">عن رقي</h1>
            <p class="text-lg md:text-xl font-sans max-w-2xl mx-auto opacity-90 leading-relaxed">
                نحن لا نصنع الأثاث؛ نحن نصمم المساحات التي تلهم الحياة وتجسد الرقي المعماري.
            </p>
        </div>
    </section>

    <!-- Our Story Section -->
    <section class="py-24 px-8 md:px-16 container-center">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-24 items-center">
            <div class="order-2 md:order-1">
                <img class="w-full aspect-[4/5] object-cover transition-all duration-1000"
                     src="https://images.unsplash.com/photo-1556228453-efd6c1ff04f6?q=80&w=800&auto=format&fit=crop"
                     alt="Craftsmanship" />
            </div>
            <div class="order-1 md:order-2 text-right">
                <span class="text-xs font-sans text-primary uppercase tracking-[0.2em] block mb-4">بدايتنا</span>
                <h2 class="text-4xl md:text-5xl font-serif text-on-surface mb-8 leading-tight">شغف بالدقة، التزام
                    بالفخامة.</h2>
                    <p class="text-lg font-sans text-secondary leading-relaxed mb-8">
                        تأسس متجر رقي برؤية واحدة: تقديم قطع أثاث تتجاوز كونها مجرد عناصر وظيفية لتصبح تحفاً معمارية. بدأنا
                        كورشة صغيرة متخصصة في النجارة اليدوية، واليوم نحن وجهة رائدة لكل من يبحث عن التميز في التصميم
                        الداخلي.
                    </p>
                    <p class="text-lg font-sans text-secondary leading-relaxed">
                        نؤمن بأن المنزل هو انعكاس للروح، ولذلك نحرص على أن تحمل كل قطعة نصنعها روح الأصالة والحداثة في آن
                        واحد.
                    </p>
                </div>
            </div>
        </section>

        <!-- Our Values -->
        <section class="bg-surface-container py-24 px-8 md:px-16">
            <div class="container-center grid grid-cols-1 md:grid-cols-3 gap-16 text-right">
                <div>
                    <span class="material-symbols-outlined text-primary text-4xl mb-6">architecture</span>
                    <h3 class="text-2xl font-serif text-on-surface mb-4">التصميم المعماري</h3>
                    <p class="text-secondary font-sans leading-relaxed">
                        نستلهم تصاميمنا من المبادئ الهندسية والمعمارية الخالدة، لنخلق قطعاً تتميز بالاتزان والجمال التركيبي.
                    </p>
                </div>
                <div>
                    <span class="material-symbols-outlined text-primary text-4xl mb-6">eco</span>
                    <h3 class="text-2xl font-serif text-on-surface mb-4">الاستدامة</h3>
                    <p class="text-secondary font-sans leading-relaxed">
                        نلتزم باستخدام موارد مستدامة وعمليات إنتاج صديقة للبيئة، لضمان مستقبل أجمل لنا ولأجيالنا.
                    </p>
                </div>
                <div>
                    <span class="material-symbols-outlined text-primary text-4xl mb-6">workspace_premium</span>
                    <h3 class="text-2xl font-serif text-on-surface mb-4">الجودة المطلقة</h3>
                    <p class="text-secondary font-sans leading-relaxed">
                        لا نساوم على الجودة. كل ملم من قطعنا يتم فحصه بعناية لضمان وصول الأفضل فقط لعملائنا.
                    </p>
                </div>
            </div>
        </section>

        <!-- Team / Vision Quote -->
        <section class="py-24 px-8 md:px-16 container-center text-center">
            <div class="max-w-4xl mx-auto">
                <span class="text-6xl font-serif text-primary/20 block mb-8">"</span>
                <p class="text-3xl md:text-4xl font-serif text-on-surface leading-tight italic mb-8">
                    نحن نؤمن بأن الجمال يكمن في التفاصيل التي لا يراها الجميع، ولكن يشعر بها كل من يسكن المكان.
                </p>
                <span class="text-xs font-sans text-primary uppercase tracking-[0.2em]">فريق رقي للتصميم</span>
            </div>
        </section>
    </main>

    @section Styles {
        <style>
            @@keyframes fadeInUp {
                from {
                    opacity: 0;
                    transform: translateY(30px);
                }

                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            .animate-fade-up {
                animation: fadeInUp 1.2s ease-out forwards;
            }
        </style>
    }
