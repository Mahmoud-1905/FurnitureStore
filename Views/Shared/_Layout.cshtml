<!DOCTYPE html>
<html class="light" lang="ar" dir="rtl">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>@ViewData["Title"] - متجر رقي</title>
    
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+Arabic:wght@400;700&family=Cairo:wght@300;400;600;700&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    
    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script id="tailwind-config">
          tailwind.config = {
            darkMode: "class",
            theme: {
              extend: {
                "colors": {
                  "surface": "#fcf9f5",
                  "surface-dim": "#dcdad6",
                  "surface-bright": "#fcf9f5",
                  "surface-container-lowest": "#ffffff",
                  "surface-container-low": "#f6f3ef",
                  "surface-container": "#f0ede9",
                  "surface-container-high": "#eae8e4",
                  "surface-container-highest": "#e5e2de",
                  "on-surface": "#1c1c1a",
                  "on-surface-variant": "#4d4639",
                  "inverse-surface": "#31302e",
                  "inverse-on-surface": "#f3f0ec",
                  "outline": "#7f7668",
                  "outline-variant": "#d1c5b5",
                  "surface-tint": "#755a22",
                  "primary": "#755a22",
                  "on-primary": "#ffffff",
                  "primary-container": "#bb9a5b",
                  "on-primary-container": "#473200",
                  "inverse-primary": "#e6c27f",
                  "secondary": "#5f5e5e",
                  "on-secondary": "#ffffff",
                  "secondary-container": "#e2dfde",
                  "on-secondary-container": "#636262",
                  "tertiary": "#4d5e86",
                  "on-tertiary": "#ffffff",
                  "tertiary-container": "#8d9eca",
                  "on-tertiary-container": "#23355b",
                  "error": "#ba1a1a",
                  "on-error": "#ffffff",
                  "error-container": "#ffdad6",
                  "on-error-container": "#93000a",
                  "primary-fixed": "#ffdea4",
                  "primary-fixed-dim": "#e6c27f",
                  "on-primary-fixed": "#261900",
                  "on-primary-fixed-variant": "#5b430b",
                  "secondary-fixed": "#e5e2e1",
                  "secondary-fixed-dim": "#c8c6c5",
                  "on-secondary-fixed": "#1c1b1b",
                  "on-secondary-fixed-variant": "#474746",
                  "tertiary-fixed": "#d9e2ff",
                  "tertiary-fixed-dim": "#b5c6f4",
                  "on-tertiary-fixed": "#051a3f",
                  "on-tertiary-fixed-variant": "#35466d",
                  "background": "#fcf9f5",
                  "on-background": "#1c1c1a",
                  "surface-variant": "#e5e2de"
                },
                "borderRadius": {
                  "none": "0",
                  "sm": "0",
                  "DEFAULT": "0",
                  "md": "0",
                  "lg": "0",
                  "xl": "0",
                  "2xl": "0",
                  "3xl": "0",
                  "full": "9999px"
                },
                "spacing": {
                  "section-gap": "160px",
                  "stack-lg": "48px",
                  "stack-md": "24px",
                  "stack-sm": "12px",
                  "gutter": "32px",
                  "unit": "8px",
                  "margin-edge": "64px"
                },
                "fontFamily": {
                  "serif": ["'Noto Serif Arabic'", "serif"],
                  "sans": ["'Cairo'", "sans-serif"]
                },
                "letterSpacing": {
                  "display": "-0.02em",
                  "headline": "-0.01em",
                  "label": "0.15em",
                  "nav": "0.05em"
                }
              },
            },
          }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        body {
            background-color: #fcf9f5;
            font-family: 'Cairo', sans-serif;
        }
        h1, h2, h3, .font-serif {
            font-family: 'Noto Serif Arabic', serif;
        }
        html {
            scroll-behavior: smooth;
        }
        .link-underline {
            position: relative;
        }
        .link-underline::after {
            content: '';
            position: absolute;
            width: 0;
            height: 1px;
            bottom: -2px;
            right: 0;
            background-color: #BB9A5B;
            transition: width 0.3s ease;
        }
        .link-underline:hover::after {
            width: 100%;
        }
        
        /* Utility for container centers */
        .container-center {
            max-width: 1440px;
            margin-left: auto;
            margin-right: auto;
            width: 100%;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="antialiased text-on-surface">

<!-- Global Navigation Bar -->
<nav class="bg-surface/80 backdrop-blur-md border-b border-outline-variant/30 sticky top-0 z-50">
    <div class="flex justify-between items-center w-full px-8 md:px-16 py-6 container-center">
        <div class="flex items-center gap-4">
            <a href="/" class="flex items-center gap-4">
                <img alt="Ruqi Logo" class="h-10 w-10 object-contain" src="/images/ruqi_logo.png"/>
                <span class="text-2xl font-serif font-bold text-on-surface tracking-tighter">رقي</span>
            </a>
        </div>
        <div class="hidden md:flex items-center gap-12">
            <a class="font-sans text-sm uppercase @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "text-primary border-b border-primary pb-1" : "text-on-surface/70 hover:text-primary link-underline") transition-colors cursor-pointer" href="/">الرئيسية</a>
            <a class="font-sans text-sm uppercase @(ViewContext.RouteData.Values["controller"]?.ToString() == "Products" ? "text-primary border-b border-primary pb-1" : "text-on-surface/70 hover:text-primary link-underline") transition-colors cursor-pointer" href="/Products">المنتجات</a>
            <a class="font-sans text-sm uppercase @(ViewContext.RouteData.Values["action"]?.ToString() == "Collections" ? "text-primary border-b border-primary pb-1" : "text-on-surface/70 hover:text-primary link-underline") transition-colors cursor-pointer" href="/Collections">المجموعات</a>
            <a class="font-sans text-sm uppercase @(ViewContext.RouteData.Values["action"]?.ToString() == "About" ? "text-primary border-b border-primary pb-1" : "text-on-surface/70 hover:text-primary link-underline") transition-colors cursor-pointer" href="/About">من نحن</a>
            
            @if (User.IsInRole("Admin"))
            {
                <a class="font-sans text-sm uppercase text-on-surface/70 hover:text-primary transition-colors cursor-pointer link-underline" href="/Admin/Dashboard">لوحة التحكم</a>
            }
        </div>
        <div class="flex items-center gap-6">
            <partial name="_LoginPartialCustom" />
            <a href="/Cart" class="material-symbols-outlined text-on-surface hover:text-primary transition-colors">
                shopping_bag
            </a>
        </div>
    </div>
</nav>

<main role="main">
    @RenderBody()
</main>

<!-- Global Footer -->
<footer class="bg-surface border-t border-outline-variant/30 py-20 mt-section-gap">
    <div class="flex flex-col md:flex-row justify-between items-center px-8 md:px-16 container-center gap-8 text-right">
        <div class="flex items-center gap-4">
            <span class="text-xl font-serif text-on-surface">أثاث رقي.</span>
        </div>
        <div class="flex flex-wrap justify-center gap-10">
            <a class="text-[10px] font-sans tracking-[0.2em] uppercase text-on-surface/50 hover:text-primary transition-colors" href="#">الخصوصية</a>
            <a class="text-[10px] font-sans tracking-[0.2em] uppercase text-on-surface/50 hover:text-primary transition-colors" href="#">الشروط</a>
            <a class="text-[10px] font-sans tracking-[0.2em] uppercase text-on-surface/50 hover:text-primary transition-colors" href="#">الصحافة</a>
            <a class="text-[10px] font-sans tracking-[0.2em] uppercase text-on-surface/50 hover:text-primary transition-colors" href="#">اتصل بنا</a>
        </div>
        <div class="text-[10px] font-sans tracking-[0.2em] uppercase text-on-surface/50">
            &copy; @DateTime.Now.Year متجر رقي. دقة معمارية.
        </div>
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)

</body>
</html>