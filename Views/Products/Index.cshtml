@model IEnumerable<FurnitureStore.Models.Product>

<style>
    .products-container {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 25px;
        padding: 40px;
    }
        
    .product-card {
        background: #fff;
        border-radius: 15px;
        overflow: hidden;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        transition: 0.3s;
    }

        .product-card:hover {
            transform: translateY(-8px);
        }

    .product-img {
        width: 100%;
        height: 200px;
        object-fit: cover;
    }

    .product-content {
        padding: 15px;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
    }

    .product-name {
        font-size: 16px;
        font-weight: bold;
        color: #333;
        margin-bottom: 10px;
        /* يخلي الاسم مرتب */
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .product-price {
        font-size: 18px;
        color: #28a745;
        font-weight: bold;
        margin-bottom: 15px;
        }

    .btn-buy {
        margin-top: auto; /* يخلي الزر تحت دايمًا */
        padding: 10px;
        border: none;
        background: #007bff;
        color: #fff;
        border-radius: 8px;
        cursor: pointer;
        transition: 0.3s;
    }

        .btn-buy:hover {
            background: #0056b3;
        }
</style>

<h2 style="text-align:center; margin:20px;">🪑 Our Products</h2>

<div class="Cards" style="display:grid; grid-template-columns:repeat(auto-fit, minmax(250px, 1fr)); gap:20px; padding:20px;">
    @foreach (var item in Model)
    {
        <div class="product-card">
            <img src="@(Url.Content(item.ImageUrl))" style="width:100%; height:200px; object-fit:cover;" />
            <div style="padding:15px; text-align:center;">
                <h3>@item.Name</h3>
                <p style="color:gray;">Price: $@item.Price</p>
                <button>Add to Cart</button>
            </div>
        </div>
    }
</div>