<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FurnitureStore</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FurnitureStore.styles.css" asp-append-version="true" />
    
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;700&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&display=swap" rel="stylesheet">
</head>
<body>
    <header>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light navbar-glass box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">FurnitureStore</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">الصفحة الرئيسية</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Products" asp-action="Index">المنتجات</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Cart" asp-action="Index">سلة المشتريات</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="Admin">المسؤول</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Dashboard">التحكم</a>
                            </li>
                        }
                        @if (User.IsInRole("User"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="User">المستخدم</a>
                            </li>
                        }
                        <partial name="_LoginPartial" />
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

   

    <footer class="modern-footer pt-5 pb-3">
        <div class="container">
            <div class="row">
                <div class="col-lg-4 col-md-6 mb-4">
                    <h5 class="fw-bold mb-4">متجر رقي</h5>
                    <p class="text-muted">
                        نحن ملتزمون بتقديم أفضل حلول الأثاث التي تجمع بين الجودة والتصميم العصري. اجعل منزلك يعكس ذوقك الرفيع.
                    </p>
                    <div class="social-icons mt-3">
                        <a href="#"><i class="bi bi-facebook ml-3"></i></a>
                        <a href="#"><i class="bi bi-instagram ml-3"></i></a>
                        <a href="#"><i class="bi bi-twitter"></i></a>
                    </div>
                </div>
                <div class="col-lg-2 col-md-6 mb-4">
                    <h6 class="fw-bold mb-4">روابط سريعة</h6>
                    <ul class="list-unstyled">
                        <li><a asp-controller="Home" asp-action="Index" class="text-muted text-decoration-none">الرئيسية</a></li>
                        <li><a asp-controller="Products" asp-action="Index" class="text-muted text-decoration-none">المنتجات</a></li>
                        <li><a asp-controller="Cart" asp-action="Index" class="text-muted text-decoration-none">السلة</a></li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-6 mb-4">
                    <h6 class="fw-bold mb-4">الدعم</h6>
                    <ul class="list-unstyled">
                        <li><a href="#" class="text-muted text-decoration-none">الخصوصية</a></li>
                        <li><a href="#" class="text-muted text-decoration-none">الشروط والأحكام</a></li>
                        <li><a href="#" class="text-muted text-decoration-none">اتصل بنا</a></li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-6 mb-4">
                    <h6 class="fw-bold mb-4">النشرة البريدية</h6>
                    <p class="text-muted small">اشترك لتصلك أحدث العروض والمنتجات.</p>
                    <div class="input-group mb-3">
                        <input type="text" class="form-control" placeholder="البريد الإلكتروني">
                        <button class="btn btn-teal-footer" type="button">اشتراك</button>
                    </div>
                </div>
            </div>
            <hr class="mt-4 mb-3 border-secondary opacity-25">
            <div class="text-center text-muted small">
                &copy; @DateTime.Now.Year - متجر رقي للأثاث. جميع الحقوق محفوظة.
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)



   
</body>
</html>