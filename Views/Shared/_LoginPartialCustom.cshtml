@using FurnitureStore.Models
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Mvc.Localization
@inject SignInManager<ApplicationUser> signInManager
@inject UserManager<ApplicationUser> userManager
@inject IViewLocalizer Localizer

<div class="flex items-center gap-6">
    @if (signInManager.IsSignedIn(User))
    {
        var user = await userManager.GetUserAsync(User);
        <div class="flex items-center gap-4">
            <span class="font-sans text-sm text-on-surface/70">@Localizer["Welcome"]، @(user?.FullName ?? User.Identity?.Name)</span>
            <form asp-controller="Account" asp-action="Logout" method="post" class="inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="font-sans text-sm uppercase text-primary hover:text-on-surface transition-colors cursor-pointer">
                    @Localizer["Logout"]
                </button>
            </form>
        </div>
    }
    else
    {
        <a asp-controller="Account" asp-action="Login" class="font-sans text-sm uppercase text-on-surface/70 hover:text-primary transition-colors cursor-pointer">
            @Localizer["Login"]
        </a>
        <a asp-controller="Account" asp-action="Register" class="font-sans text-sm uppercase text-primary border border-primary px-4 py-2 hover:bg-primary hover:text-surface transition-all cursor-pointer">
            @Localizer["Register"]
        </a>
    }
</div>
