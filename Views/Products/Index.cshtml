@model IEnumerable<FurnitureStore.Models.Product>

<style>
    body {
        font-family: Arial;
        background: #f5f5f5;
    }

    .product-card {
        background: white;
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        transition: 0.3s;
    }

        .product-card:hover {
            transform: scale(1.05);
        }

    button {
        background: #007bff;
        color: white;
        border: none;
        padding: 8px 15px;
        cursor: pointer;
        border-radius: 5px;
    }

        button:hover {
            background: #0056b3;
        }
</style>

<h2 style="text-align:center; margin:20px;">🪑 Our Products</h2>

<div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(250px, 1fr)); gap:20px; padding:20px;">
    @foreach (var item in Model)
    {
        <div class="product-card">
            <img src="@(Url.Content(item.ImageUrl))" style="width:100%; height:200px; object-fit:cover;" />
            <div style="padding:15px; text-align:center;">
                <h3>@item.Name</h3>
                <p style="color:gray;">Price: $@item.Price</p>
                <button>Add to Cart</button>
            </div>
        </div>
    }
</div>