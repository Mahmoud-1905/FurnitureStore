@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = Localizer["Title"];
}

<main class="py-24 px-8 md:px-16 container-center min-h-[60vh] text-right">
    <h1 class="text-4xl font-serif text-on-surface mb-8">@ViewData["Title"]</h1>
    <div class="prose prose-stone max-w-none">
        <p class="text-lg text-secondary font-sans leading-relaxed">
            @Localizer["Content"]
        </p>
    </div>
</main>

