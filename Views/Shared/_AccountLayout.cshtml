@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@{
    var culture = System.Threading.Thread.CurrentThread.CurrentCulture.Name;
    var isRtl = culture.StartsWith("ar");
}
<!DOCTYPE html>
<html lang="@culture" dir="@(isRtl ? "rtl" : "ltr")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @Localizer["BrandTitle"]</title>
    
    <!-- Typography -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+Arabic:wght@300;400;600;700&family=Cairo:wght@200;300;400;600;700&display=swap" rel="stylesheet">
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'surface': '#fcf9f5',
                        'on-surface': '#1c1c1a',
                        'primary': '#755a22',
                        'secondary': '#5f5e5e',
                        'outline-variant': '#d1c5b5',
                        'error': '#ba1a1a',
                    },
                    fontFamily: {
                        'serif': ['"Noto Serif Arabic"', 'serif'],
                        'sans': ['Cairo', 'sans-serif'],
                    },
                    borderRadius: {
                        'none': '0',
                    }
                }
            }
        }
    </script>
    <style type="text/css">
        body {
            background-color: #fcf9f5;
            background-image: radial-gradient(#d1c5b5 0.5px, transparent 0.5px);
            background-size: 24px 24px;
        }
        .form-input {
            width: 100%;
            background-color: transparent;
            border-top: none;
            border-left: none;
            border-right: none;
            border-bottom: 1px solid #d1c5b5;
            padding: 0.75rem 0;
            transition: border-color 0.3s ease;
            font-family: 'Cairo', sans-serif;
            outline: none;
            color: #1c1c1a;
        }
        .form-input:focus {
            border-color: #755a22;
            box-shadow: none;
        }
        .form-label {
            display: block;
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 0.2em;
            color: #5f5e5e;
            margin-bottom: 0.5rem;
            font-family: 'Cairo', sans-serif;
        }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center p-8">
    <div class="w-full max-w-md bg-white p-12 shadow-[20px_20px_60px_#eae8e4,-20px_-20px_60px_#ffffff] border border-outline-variant/20">
        <!-- Brand Signature -->
        <div class="text-center mb-12">
            <a href="/" class="inline-block">
                <span class="text-3xl font-serif tracking-[0.3em] text-on-surface uppercase">RUQI</span>
                <span class="block text-[8px] tracking-[0.5em] text-primary mt-2">@Localizer["InteriorArchitecture"]</span>
            </a>
        </div>

        @RenderBody()
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>