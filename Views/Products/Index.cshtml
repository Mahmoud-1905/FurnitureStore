@model List<FurnitureStore.Models.Product>

<h2 style="text-align:center; margin:20px 0; font-family:Arial, sans-serif;">🪑 Our Products</h2>

<div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(250px, 1fr)); gap:20px; padding:20px;">
    @foreach (var item in Model)
    {
        <div class="product-card">
            <img src="@(Url.Content(item.ImageUrl))" style="width:100%; height:200px; object-fit:cover;" />
            <div style="padding:15px; text-align:center;">
                <h3>@item.Name</h3>
                <p>Price: $@item.Price</p>
                <button>Add to Cart</button>
            </div>
        </div>
    }
</div>

