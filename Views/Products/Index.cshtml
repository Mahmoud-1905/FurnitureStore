@model List<FurnitureStore.Models.Product>

@{
    ViewData["Title"] = "منتجاتنا - فخامة معمارية";
}

<div class="py-12 px-8 md:px-16 container-center">
    <!-- Page Header -->
    <div class="mb-16 text-right">
        <span class="text-xs font-sans text-primary uppercase tracking-[0.2em] block mb-stack-sm">استكشف</span>
        <h1 class="text-5xl font-serif text-on-surface">منتجاتنا المختارة</h1>
        <div class="w-24 h-[1px] bg-outline-variant mt-6"></div>
    </div>

    <!-- Search Section -->
    <div class="mb-16">
        <form asp-action="Index" method="get" class="flex flex-col md:flex-row gap-6 items-end md:items-center justify-start border-b border-outline-variant pb-8">
            <div class="flex-1 w-full relative">
                <input type="text" name="searchTerm" 
                       class="w-full bg-transparent border-none focus:ring-0 font-sans text-lg placeholder:text-secondary/50 text-right pr-0" 
                       placeholder="ابحث عن قطعة أثاث محددة..." 
                       value="@ViewBag.SearchTerm" />
            </div>
            
            <div class="flex items-center gap-6">
                @if (!string.IsNullOrEmpty(ViewBag.SearchTerm as string))
                {
                    <a asp-action="Index" class="text-xs font-sans text-error uppercase tracking-widest hover:opacity-70 transition-opacity">
                        ✕ مسح البحث
                    </a>
                }
                <button type="submit" class="bg-on-surface text-surface px-8 py-3 font-sans text-sm uppercase tracking-widest hover:bg-primary transition-colors">
                    بحث معماري
                </button>
            </div>
        </form>
    </div>

    <!-- Products Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-x-gutter gap-y-24">
        @foreach (var item in Model)
        {
            <div class="group flex flex-col h-full bg-surface-container-low/30">
                <!-- Image Container -->
                <div class="relative aspect-[4/5] overflow-hidden bg-surface-container mb-6">
                    <img src="@Url.Content(item.ImageUrl)" 
                         class="w-full h-full object-cover transition-all duration-1000 group-hover:scale-105" 
                         alt="@item.Name" />
                    
                    <div class="absolute top-0 right-0 p-4">
                        <span class="bg-on-surface text-surface text-[10px] uppercase tracking-[0.2em] px-3 py-1">
                            @item.Category?.Name
                        </span>
                    </div>

                    <!-- Quick Add Hover -->
                    <div class="absolute inset-0 bg-on-surface/40 opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-center justify-center">
                        <a asp-controller="Cart"
                           asp-action="AddToCart"
                           asp-route-name="@item.Name"
                           asp-route-price="@item.Price"
                           asp-route-image="@item.ImageUrl"
                           class="bg-surface text-on-surface px-8 py-3 font-sans text-xs uppercase tracking-widest hover:bg-primary hover:text-surface transition-colors">
                            @(User.Identity.IsAuthenticated ? "إضافة للسلة" : "سجل دخول للإضافة")
                        </a>
                    </div>
                </div>

                <!-- Content -->
                <div class="flex flex-col flex-1 px-2 text-right">
                    <div class="flex justify-between items-start mb-2 flex-row-reverse">
                        <h3 class="text-xl font-serif text-on-surface group-hover:text-primary transition-colors">@item.Name</h3>
                        <span class="text-lg font-sans text-on-surface font-semibold">₪@item.Price</span>
                    </div>
                    
                    <p class="text-sm font-sans text-secondary mb-6 line-clamp-2 leading-relaxed">
                        @item.Description
                    </p>

                    <div class="mt-auto pt-4 border-t border-outline-variant/30 flex justify-between items-center flex-row-reverse">
                        <a asp-controller="Products"
                           asp-action="Details"
                           asp-route-id="@item.ProductId" 
                           class="text-[10px] font-sans text-primary uppercase tracking-[0.2em] border-b border-primary/0 hover:border-primary transition-all">
                            التفاصيل الكاملة
                        </a>
                        <div class="flex gap-1">
                            <span class="material-symbols-outlined text-[14px] text-primary-container">star</span>
                            <span class="material-symbols-outlined text-[14px] text-primary-container">star</span>
                            <span class="material-symbols-outlined text-[14px] text-primary-container">star</span>
                            <span class="material-symbols-outlined text-[14px] text-primary-container">star</span>
                            <span class="material-symbols-outlined text-[14px] text-primary-container">star_half</span>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="py-32 text-center">
            <p class="text-xl font-serif text-secondary">لم يتم العثور على قطع تطابق بحثك.</p>
            <a asp-action="Index" class="text-sm font-sans text-primary uppercase tracking-widest mt-6 inline-block border-b border-primary">العودة للمجموعة الكاملة</a>
        </div>
    }
</div>