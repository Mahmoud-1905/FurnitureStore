@using Microsoft.AspNetCore.Localization
@using Microsoft.AspNetCore.Mvc.Localization
@using Microsoft.AspNetCore.Http
@using System.Text.Json
@using FurnitureStore.ViewModels
@inject IViewLocalizer Localizer
@{
    var requestCultureFeature = Context.Features.Get<IRequestCultureFeature>();
    var currentCulture = requestCultureFeature?.RequestCulture.Culture.Name ?? "ar";
    var isRtl = currentCulture.StartsWith("ar");
    var htmlLang = isRtl ? "ar" : "en";
    var htmlDir = isRtl ? "rtl" : "ltr";

    bool hasCartItems = false;
    var cartSession = Context.Session.GetString("CartSession");
    if (!string.IsNullOrEmpty(cartSession))
    {
        var cart = JsonSerializer.Deserialize<List<CartSessionItem>>(cartSession);
        if (cart != null && cart.Count > 0)
        {
            hasCartItems = true;
        }
    }
}
<!DOCTYPE html>
<html class="light" lang="@htmlLang" dir="@htmlDir">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"] - @Localizer["StoreName"]</title>

    <!-- Fonts -->
    <link
    href="https://fonts.googleapis.com/css2?family=Noto+Serif+Arabic:wght@400;700&family=Cairo:wght@300;400;600;700&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
    rel="stylesheet" />

    <!-- Bootstrap 5 -->
    @if (isRtl)
    {
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css"
              integrity="sha384-dpuaG1suU0eT09tx5plTaGMLBsfDLzUCCUXOY2j/LSvXYuG6Bqs43ALlhIqAJVRb" crossorigin="anonymous">
    }
    else
    {
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
              integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    }

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script id="tailwind-config">
        tailwind.config = {
        darkMode: "class",
        theme: {
        extend: {
        "colors": {
        "surface": "#fcf9f5",
        "surface-dim": "#dcdad6",
        "surface-bright": "#fcf9f5",
        "surface-container-lowest": "#ffffff",
        "surface-container-low": "#f6f3ef",
        "surface-container": "#f0ede9",
        "surface-container-high": "#eae8e4",
        "surface-container-highest": "#e5e2de",
        "on-surface": "#1c1c1a",
        "on-surface-variant": "#4d4639",
        "inverse-surface": "#31302e",
        "inverse-on-surface": "#f3f0ec",
        "outline": "#7f7668",
        "outline-variant": "#d1c5b5",
        "surface-tint": "#755a22",
        "primary": "#755a22",
        "on-primary": "#ffffff",
        "primary-container": "#bb9a5b",
        "on-primary-container": "#473200",
        "inverse-primary": "#e6c27f",
        "secondary": "#5f5e5e",
        "on-secondary": "#ffffff",
        "secondary-container": "#e2dfde",
        "on-secondary-container": "#636262",
        "tertiary": "#4d5e86",
        "on-tertiary": "#ffffff",
        "tertiary-container": "#8d9eca",
        "on-tertiary-container": "#23355b",
        "error": "#ba1a1a",
        "on-error": "#ffffff",
        "error-container": "#ffdad6",
        "on-error-container": "#93000a",
        "primary-fixed": "#ffdea4",
        "primary-fixed-dim": "#e6c27f",
        "on-primary-fixed": "#261900",
        "on-primary-fixed-variant": "#5b430b",
        "secondary-fixed": "#e5e2e1",
        "secondary-fixed-dim": "#c8c6c5",
        "on-secondary-fixed": "#1c1b1b",
        "on-secondary-fixed-variant": "#474746",
        "tertiary-fixed": "#d9e2ff",
        "tertiary-fixed-dim": "#b5c6f4",
        "on-tertiary-fixed": "#051a3f",
        "on-tertiary-fixed-variant": "#35466d",
        "background": "#fcf9f5",
        "on-background": "#1c1c1a",
        "surface-variant": "#e5e2de"
        },
        "borderRadius": {
        "none": "0",
        "sm": "0",
        "DEFAULT": "0",
        "md": "0",
        "lg": "0",
        "xl": "0",
        "2xl": "0",
        "3xl": "0",
        "full": "9999px"
        },
        "spacing": {
        "section-gap": "160px",
        "stack-lg": "48px",
        "stack-md": "24px",
        "stack-sm": "12px",
        "gutter": "32px",
        "unit": "8px",
        "margin-edge": "64px"
        },
        "fontFamily": {
        "serif": ["'Noto Serif Arabic'", "serif"],
        "sans": ["'Cairo'", "sans-serif"]
        },
        "letterSpacing": {
        "display": "-0.02em",
        "headline": "-0.01em",
        "label": "0.15em",
        "nav": "0.05em"
        }
        },
        },
        }
    </script>
    <style>
        .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        body {
        background-color: #fcf9f5;
        font-family: 'Cairo', sans-serif;
        }

        h1,
        h2,
        h3,
        .font-serif {
        font-family: 'Noto Serif Arabic', serif;
        }

        html {
        scroll-behavior: smooth;
        }

        .link-underline {
        position: relative;
        text-decoration: none !important;
        }

        .link-underline::after {
        content: '';
        position: absolute;
        width: 0;
        height: 1px;
        bottom: -2px;
        right: 0;
        background-color: #BB9A5B;
        transition: width 0.3s ease;
        }

        .link-underline:hover::after {
        width: 100%;
        }

        /* Utility for container centers */
        .container-center {
        max-width: 1440px;
        margin-left: auto;
        margin-right: auto;
        width: 100%;
        }

        /* Fix Bootstrap overrides */
        a {
        text-decoration: none;
        }

        .btn {
        border-radius: 0;
        }
        
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>

<body class="antialiased text-on-surface">

    <!-- Global Navigation Bar -->
    <nav class="bg-surface/80 backdrop-blur-md border-b border-outline-variant/30 sticky top-0 z-50">
        <div class="flex justify-between items-center w-full px-8 md:px-16 py-6 container-center">
            <div class="flex items-center gap-4">
                <a href="/" class="flex items-center gap-4">
                    <img alt="Ruqi Logo" class="h-10 w-10 object-contain" src="/images/ruqi_logo.png" />
                    <span
                    class="text-2xl font-serif font-bold text-on-surface tracking-tighter">@Localizer["StoreName"]</span>
                </a>
            </div>
            <div class="hidden md:flex items-center gap-12">
                <a class="font-sans text-sm uppercase @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "text-primary border-b border-primary pb-1" : "text-on-surface/70 hover:text-primary link-underline") transition-colors cursor-pointer"
                   href="/">@Localizer["Home"]</a>
                <a class="font-sans text-sm uppercase @(ViewContext.RouteData.Values["controller"]?.ToString() == "Products" ? "text-primary border-b border-primary pb-1" : "text-on-surface/70 hover:text-primary link-underline") transition-colors cursor-pointer"
                   href="/Products">@Localizer["Products"]</a>
                <a class="font-sans text-sm uppercase @(ViewContext.RouteData.Values["action"]?.ToString() == "Collections" ? "text-primary border-b border-primary pb-1" : "text-on-surface/70 hover:text-primary link-underline") transition-colors cursor-pointer"
                   href="/Collections">@Localizer["Collections"]</a>
                <a class="font-sans text-sm uppercase @(ViewContext.RouteData.Values["action"]?.ToString() == "About" ? "text-primary border-b border-primary pb-1" : "text-on-surface/70 hover:text-primary link-underline") transition-colors cursor-pointer"
                   href="/About">@Localizer["AboutUs"]</a>

                @if (User.IsInRole("Admin"))
                {
                    <a class="font-sans text-sm uppercase text-on-surface/70 hover:text-primary transition-colors cursor-pointer link-underline"
                       href="/Admin/Dashboard">@Localizer["AdminDashboard"]</a>
                }
            </div>
            <div class="flex items-center gap-6">
                <partial name="_LoginPartialCustom" />
                <button id="langToggle"
                        class="material-symbols-outlined text-on-surface hover:text-primary transition-colors bg-transparent border-0 cursor-pointer p-0"
                        data-target-lang="@(isRtl ? "en" : "ar")" title="@(isRtl ? "English" : "عربي")">
                    translate
                </button>
                <a href="/Cart" id="cartIcon"
                   class="material-symbols-outlined text-on-surface hover:text-primary transition-colors relative">
                    shopping_bag
                    <span id="cartCheckmark"
                          class="@(hasCartItems ? "" : "hidden") absolute -top-1 -right-1 bg-primary text-surface rounded-full text-[10px] w-4 h-4 flex items-center justify-center font-bold">✓</span>
                </a>
            </div>
        </div>
    </nav>

    <main role="main">
        @RenderBody()
    </main>

    <!-- Global Footer -->
    <footer class="border-t border-outline-variant/30 py-10" style="background: #e2c7a3">
        <div
            class="flex flex-col md:flex-row justify-between items-center px-8 md:px-16 container-center gap-8 text-right"
            style="opacity: 0.9;">
            <div class="flex items-center gap-4">
                <span class="font-serif text-on-surface" style="font-size: 60px;  font-weight: bold;">@Localizer["Ruqi"]</span>
            </div>
            <div class="flex flex-wrap justify-center gap-10">
                <a class="text-[15px] font-sans tracking-[0.2em] uppercase text-on-surface/50 hover:text-primary transition-colors"
                   href="#">@Localizer["Privacy"]</a>
                <a class="text-[15px] font-sans tracking-[0.2em] uppercase text-on-surface/50 hover:text-primary transition-colors"
                   href="#">@Localizer["Terms"]</a>
                <a class="text-[15px] font-sans tracking-[0.2em] uppercase text-on-surface/50 hover:text-primary transition-colors"
                   href="#">@Localizer["Press"]</a>
                <a class="text-[15px] font-sans tracking-[0.2em] uppercase text-on-surface/50 hover:text-primary transition-colors"
                   href="#">@Localizer["ContactUs"]</a>
            </div>
            <div class="text-[15px] font-sans tracking-[0.2em] uppercase text-on-surface/50">
                &copy; @DateTime.Now.Year @Localizer["Copyright"]
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmxc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
            crossorigin="anonymous"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
        var langToggle = document.getElementById("langToggle");
        if (langToggle) {
        langToggle.addEventListener("click", function () {
        var targetLang = this.getAttribute("data-target-lang");
        var cookieValue = "c=" + targetLang + "|uic=" + targetLang;
        document.cookie = ".AspNetCore.Culture=" + cookieValue + ";path=/";
        window.location.reload();
        });
        }

        // Add to cart AJAX intercept
        function fetchAddToCart(url) {
        fetch(url, {
        method: 'GET',
        headers: {
        'X-Requested-With': 'XMLHttpRequest'
        }
        }).then(response => {
        if (response.url && response.url.toLowerCase().includes('login')) {
        window.location.href = response.url;
        return;
        }
        const cartCheckmark = document.getElementById('cartCheckmark');
        if (cartCheckmark) {
        cartCheckmark.classList.remove('hidden');
        cartCheckmark.classList.add('animate-bounce');
        setTimeout(() => {
        cartCheckmark.classList.remove('animate-bounce');
        }, 1000);
        }
        }).catch(err => console.error(err));
        }

        document.addEventListener('click', function (e) {
        const target = e.target.closest('a[href*="AddToCart"]');
        if (target) {
        e.preventDefault();
        fetchAddToCart(target.href);
        }
        });

        document.addEventListener('submit', function (e) {
        const target = e.target.closest('form[action*="AddToCart"]');
        if (target) {
        e.preventDefault();
        const url = new URL(target.action, window.location.origin);
        const formData = new FormData(target);
        for (const pair of formData.entries()) {
        url.searchParams.append(pair[0], pair[1]);
        }
        fetchAddToCart(url.toString());
        }
        });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>