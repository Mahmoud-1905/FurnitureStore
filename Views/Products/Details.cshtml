@model FurnitureStore.Models.Product

@{
    ViewData["Title"] = $"{Model.Name} - دقة معمارية";
}

<div class="py-24 px-8 md:px-16 container-center">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
        <!-- Product Image -->
        <div class="lg:col-span-7">
            <div class="relative overflow-hidden bg-surface-container aspect-square md:aspect-[4/5]">
                <img src="@Url.Content(Model.ImageUrl)" 
                     class="w-full h-full object-cover transition-all duration-1000" 
                     alt="@Model.Name" />
                <div class="absolute top-0 right-0 p-8">
                    <span class="text-[10px] font-sans text-on-surface bg-surface px-4 py-2 uppercase tracking-[0.2em]">
                        الرقم المرجعي: #@Model.ProductId
                    </span>
                </div>
            </div>
        </div>

        <!-- Product Details -->
        <div class="lg:col-span-5 text-right">
            <div class="mb-12">
                <span class="text-xs font-sans text-primary uppercase tracking-[0.2em] block mb-stack-sm">@Model.Category?.Name</span>
                <h1 class="text-5xl font-serif text-on-surface mb-6 leading-tight">@Model.Name</h1>
                <div class="text-3xl font-sans text-on-surface font-light mb-8">₪@Model.Price</div>
                <div class="w-16 h-[1px] bg-outline-variant"></div>
            </div>

            <p class="text-lg font-sans text-secondary mb-12 leading-relaxed">
                @Model.Description
            </p>

            <!-- Purchase Form -->
            <form method="get" asp-controller="Cart" asp-action="AddToCart" class="space-y-8">
                <input type="hidden" name="name"  value="@Model.Name" />
                <input type="hidden" name="price" value="@Model.Price" />
                <input type="hidden" name="image" value="@Model.ImageUrl" />

                <div class="flex items-center justify-end gap-6">
                    <div class="relative">
                        <label class="text-[10px] font-sans text-secondary uppercase tracking-[0.2em] block mb-2">الكمية</label>
                        <input type="number" name="quantity" value="1" min="1" 
                               class="bg-transparent border-b border-on-surface focus:ring-0 focus:border-primary w-24 text-center font-sans text-lg py-2" />
                    </div>
                </div>

                <div class="flex flex-col gap-4 pt-8">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <button type="submit" class="w-full bg-on-surface text-surface py-5 font-sans text-sm uppercase tracking-[0.2em] hover:bg-primary transition-colors duration-500">
                            اقتناء هذه القطعة
                        </button>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" class="block text-center w-full bg-primary text-surface py-5 font-sans text-sm uppercase tracking-[0.2em] hover:bg-on-surface transition-colors duration-500">
                            تسجيل الدخول للاقتناء
                        </a>
                    }
                    <a asp-controller="Products" asp-action="Index" 
                       class="text-center text-xs font-sans text-primary uppercase tracking-widest border-b border-primary/0 hover:border-primary py-2 transition-all">
                        ← العودة للمجموعة الكاملة
                    </a>
                </div>
            </form>

            <!-- Quality Assurance -->
            <div class="mt-16 grid grid-cols-2 gap-8 border-t border-outline-variant/30 pt-8">
                <div>
                    <h4 class="text-[10px] font-sans text-on-surface uppercase tracking-[0.1em] mb-2">مواد مستدامة</h4>
                    <p class="text-xs font-sans text-secondary">صُنع بعناية من أجود أنواع الأخشاب الطبيعية.</p>
                </div>
                <div>
                    <h4 class="text-[10px] font-sans text-on-surface uppercase tracking-[0.1em] mb-2">شحن معماري</h4>
                    <p class="text-xs font-sans text-secondary">تغليف خاص يضمن وصول القطعة بدقتها الأصلية.</p>
                </div>
            </div>
        </div>
    </div>
</div>