@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = Localizer["HeroTitle"].Value.Replace("<br />", " ");
}

@section Styles {

    <!-- Swiper -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper/swiper-bundle.min.css" />

    <style>
        /* =========================
                                   HERO ANIMATIONS
                                ========================== */

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(40px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .animate-fade-up {
            animation: fadeInUp 1.2s ease-out forwards;
        }

        @@keyframes slowZoom {
            0% {
                transform: scale(1.05);
            }

            100% {
                transform: scale(1.15);
            }
        }

        .animate-slow-zoom {
            animation: slowZoom 12s ease-in-out infinite alternate;
        }

        @@keyframes floatY {
            0% {
                transform: translateY(0px);
            }

            50% {
                transform: translateY(-10px);
            }

            100% {
                transform: translateY(0px);
            }
        }

        .animate-float {
            animation: floatY 5s ease-in-out infinite;
        }

        /* =========================
                                   GLASS EFFECT
                                ========================== */

        .glass-card {
            backdrop-filter: blur(18px);
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        /* =========================
                                   HOVER EFFECT
                                ========================== */

        .hover-lift {
            transition: all .6s ease;
        }

        .hover-lift:hover {
            transform: translateY(-12px);
            box-shadow: 0 30px 60px rgba(0, 0, 0, .18);
        }

        /* =========================
                                   SCROLL REVEAL
                                ========================== */

        .hidden-element {
            opacity: 0;
            transform: translateY(60px);
            transition: all 1s ease;
        }

        .show-element {
            opacity: 1;
            transform: translateY(0);
        }

        /* =========================
                                   BUTTON EFFECT
                                ========================== */

        .premium-btn {
            position: relative;
            overflow: hidden;
        }

        .premium-btn::before {
            content: "";
            position: absolute;
            inset: 0;
            background: #c8a97e;
            transform: translateY(100%);
            transition: .5s ease;
            z-index: 0;
        }

        .premium-btn:hover::before {
            transform: translateY(0);
        }

        .premium-btn span {
            position: relative;
            z-index: 10;
        }

        /* =========================
                                   SWIPER
                                ========================== */

        .luxurySwiper .swiper-slide {
            transition: .6s ease;
            opacity: .5;
            transform: scale(.92);
        }

        .luxurySwiper .swiper-slide-active {
            opacity: 1;
            transform: scale(1);
        }

        .py-section-gap {
            padding-top: 100px !important;
            padding-bottom: 0 !important;
        }
    </style>
}

<main>

    <!-- =========================
         HERO SECTION
    ========================== -->

    <section class="relative min-h-[95vh] flex flex-col justify-center px-8 md:px-16 overflow-hidden">

        <!-- Background -->
        <div class="absolute inset-0 -z-10 overflow-hidden">

            <div class="absolute inset-0 bg-gradient-to-br from-black/60 via-black/20 to-black/70 z-10"></div>

            <img class="w-full h-full object-cover animate-slow-zoom"
                 src="https://images.unsplash.com/photo-1618221195710-dd6b41faaea6?q=80&w=2000&auto=format&fit=crop" />

            <!-- Blur Effects -->
            <div class="absolute top-10 left-10 w-72 h-72 bg-primary/20 rounded-full blur-3xl animate-pulse"></div>

            <div class="absolute bottom-10 right-10 w-96 h-96 bg-white/10 rounded-full blur-3xl animate-pulse"></div>

        </div>

        <div class="container-center grid grid-cols-1 md:grid-cols-12 gap-gutter">

            <div class="md:col-span-8 flex flex-col justify-center animate-fade-up">

                <h1 class="text-6xl md:text-8xl font-serif text-white mb-stack-md leading-tight">
                    @Html.Raw(Localizer["HeroTitle"].Value)
                </h1>

                <p class="text-xl md:text-2xl font-sans text-white/80 max-w-xl mb-stack-lg leading-relaxed">
                    @Localizer["HeroSubtitle"]
                </p>

                <div class="flex flex-wrap gap-stack-md items-center">

                    <!-- BUTTON -->
                    <a href="/Products"
                       class="premium-btn bg-white text-black px-10 py-4 uppercase tracking-widest text-sm transition-all duration-500">

                        <span>
                            @Localizer["ExploreCollection"]
                        </span>

                    </a>

                    <!-- BUTTON -->
                    <a href="/Gallery"
                       class="border border-white text-white px-10 py-4 uppercase tracking-widest text-sm hover:bg-white hover:text-black transition-all duration-500">

                        @Localizer["ViewGallery"]

                    </a>

                </div>

            </div>

        </div>

    </section>

    <!-- =========================
         PHILOSOPHY SECTION
    ========================== -->

    <section class="py-section-gap px-8 md:px-16 bg-surface hidden-element">

        <div class="container-center grid grid-cols-1 md:grid-cols-12 items-center gap-16">

            <div class="md:col-span-5 order-2 ltr:md:order-1 rtl:md:order-1 ltr:text-left rtl:text-right">

                <span class="text-xs text-primary uppercase tracking-[0.2em] block mb-stack-sm">
                    @Localizer["PhilosophySubtitle"]
                </span>

                <h2 class="text-4xl md:text-5xl font-serif text-on-surface mb-stack-md leading-tight">
                    @Localizer["PhilosophyTitle"]
                </h2>

                <p class="text-lg text-secondary leading-relaxed">
                    @Localizer["PhilosophyText"]
                </p>

                <a href="/About"
                   class="inline-flex items-center gap-3 text-primary hover:text-black transition-colors group mt-4">
                    <span class="text-sm uppercase tracking-widest font-medium">@Localizer["DiscoverAll"]</span>
                    <span class="w-8 h-[1px] bg-primary group-hover:w-12 transition-all duration-300"></span>
                    <svg class="w-4 h-4 transform rtl:rotate-180 group-hover:translate-x-1 rtl:group-hover:-translate-x-1 transition-transform"
                         fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                    </svg>
                </a>

            </div>

            <div class="md:col-span-7 order-1 ltr:md:order-2 rtl:md:order-2 flex justify-center">

                <div class="grid grid-cols-2 gap-4 md:gap-6 w-11/12 lg:w-4/5">

                    <img class="w-full aspect-[4/5] object-cover rounded-[24px] hover-lift shadow-lg"
                         src="https://cdn.salla.sa/PdZwwe/56e56ab7-6de6-48e1-8356-f0ab8c26bff1-993.97590361446x1000-hTQj86YWlbfsvAxJbnRXuGdCR4HeY4Z4RfADCijZ.png" />

                    <img class="w-full aspect-[4/5] object-cover mt-12 md:mt-20 rounded-[24px] hover-lift shadow-lg"
                         src="https://images.unsplash.com/photo-1616046229478-9901c5536a45?q=80&w=800&auto=format&fit=crop" />

                </div>

            </div>

        </div>

    </section>

    <!-- =========================
         SWIPER SECTION
    ========================== -->

    <section class="py-32 px-8 md:px-16 bg-surface hidden-element">

        <div class="mb-16 text-right">

            <span class="text-xs text-primary uppercase tracking-[0.2em] block mb-stack-sm">
                Luxury Collection
            </span>

            <h2 class="text-5xl font-serif">
                Featured Spaces
            </h2>

        </div>

        <div class="swiper luxurySwiper overflow-visible">

            <div class="swiper-wrapper">

                <div class="swiper-slide">

                    <img class="w-full h-[700px] object-cover rounded-[40px]"
                         src="https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?q=80&w=2000&auto=format&fit=crop" />

                </div>

                <div class="swiper-slide">

                    <img class="w-full h-[700px] object-cover rounded-[40px]"
                         src="https://images.unsplash.com/photo-1494526585095-c41746248156?q=80&w=2000&auto=format&fit=crop" />

                </div>

                <div class="swiper-slide">

                    <img class="w-full h-[700px] object-cover rounded-[40px]"
                         src="https://images.unsplash.com/photo-1484154218962-a197022b5858?q=80&w=2000&auto=format&fit=crop" />

                </div>

            </div>

        </div>

    </section>

</main>

@section Scripts {

    <script src="https://cdn.jsdelivr.net/npm/swiper/swiper-bundle.min.js"></script>

    <script>

        // =========================
        // SWIPER
        // =========================

        new Swiper(".luxurySwiper", {

        loop: true,

        speed: 1500,

        autoplay: {
        delay: 3500,
        },

        slidesPerView: 1.2,

        centeredSlides: true,

        spaceBetween: 30,

        });

        // =========================
        // SCROLL REVEAL
        // =========================

        const observer = new IntersectionObserver((entries) => {

        entries.forEach((entry) => {

        if (entry.isIntersecting) {

        entry.target.classList.add("show-element");

        }

        });

        });

        document.querySelectorAll(".hidden-element").forEach((el) => {

        observer.observe(el);

        });

    </script>

}