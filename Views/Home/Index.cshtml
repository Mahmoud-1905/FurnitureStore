@{
    ViewData["Title"] = "الرئيسية - دقة معمارية وفخامة هادئة";
}

@section Styles {
    <style>
        /* Animation for hero */
        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .animate-fade-up {
            animation: fadeInUp 1.2s ease-out forwards;
        }
    </style>
}

<main>
    <!-- Hero Section -->
    <section class="relative min-h-[90vh] flex flex-col justify-center px-8 md:px-16 overflow-hidden">
        <div class="absolute inset-0 -z-10">
            <div class="absolute inset-0 bg-black/5"></div>
            <img class="w-full h-full object-cover"
                 src="https://images.unsplash.com/photo-1618221195710-dd6b41faaea6?q=80&w=2000&auto=format&fit=crop" />
        </div>
        <div class="container-center grid grid-cols-1 md:grid-cols-12 gap-gutter">
            <div class="md:col-span-8 flex flex-col justify-center animate-fade-up">
                <h1 class="text-6xl md:text-8xl font-serif text-primary mb-stack-md leading-tight">
                    حياة عصرية،<br />تصاميم خالدة
                </h1>
                <p class="text-xl md:text-2xl font-sans text-on-surface-variant max-w-xl mb-stack-lg leading-relaxed">
                    نرتدي بجمالية منزلك من خلال قطع مختارة بعناية تجمع بين الدقة المعمارية والفخامة الهادئة.
                </p>
                <div class="flex flex-wrap gap-stack-md items-center">
                    <a href="/Products"
                       class="bg-on-surface text-surface px-10 py-4 font-sans text-sm uppercase tracking-widest hover:bg-primary transition-colors duration-500 text-center">
                        استكشف المجموعة
                    </a>
                    <a href="/Gallery"
                       class="border border-on-surface text-on-surface px-10 py-4 font-sans text-sm uppercase tracking-widest hover:border-primary hover:text-primary transition-colors duration-500 text-center">
                        عرض المعرض
                    </a>
                </div>
            </div>
        </div>

        <!-- Hero Metrics -->
        <div class="absolute bottom-16 right-8 md:right-16 flex gap-12 text-right">
            <div>
                <p class="text-3xl font-serif text-primary">500+</p>
                <p class="text-[10px] font-sans uppercase tracking-[0.2em] text-on-surface-variant">قطعة فريدة</p>
            </div>
            <div>
                <p class="text-3xl font-serif text-primary">15k+</p>
                <p class="text-[10px] font-sans uppercase tracking-[0.2em] text-on-surface-variant">منزل سعيد</p>
            </div>
        </div>
    </section>

    <!-- Our Philosophy Section -->
    <section class="py-section-gap px-8 md:px-16 bg-surface">
        <div class="container-center grid grid-cols-1 md:grid-cols-12 items-center gap-16">
            <div class="md:col-span-5 order-2 md:order-1">
                <span class="text-xs font-sans text-primary uppercase tracking-[0.2em] block mb-stack-sm">فلسفتنا</span>
                <h2 class="text-4xl md:text-5xl font-serif text-on-surface mb-stack-md leading-tight">
                    الدقة المعمارية في كل تفصيل.
                </h2>
                <p class="text-lg font-sans text-secondary mb-stack-lg leading-relaxed">
                    نؤمن بأن الأثاث هو عمارة التصميم الداخلي. كل قطعة في مجموعة رقي صُنعت بعناية فائقة باستخدام مواد
                    مستدامة عالية الجودة، لضمان التوازن بين الصدق الإنشائي والراحة الفاخرة.
                </p>
                <div class="w-24 h-[1px] bg-outline-variant"></div>
            </div>
            <div class="md:col-span-7 order-1 md:order-2">
                <div class="grid grid-cols-2 gap-stack-md">
                    <img class="w-full aspect-[4/5] object-cover transition-all duration-700 hover:scale-105"
                         src="https://cdn.salla.sa/PdZwwe/56e56ab7-6de6-48e1-8356-f0ab8c26bff1-993.97590361446x1000-hTQj86YWlbfsvAxJbnRXuGdCR4HeY4Z4RfADCijZ.png" />
                    <img class="w-full aspect-[4/5] object-cover mt-12 transition-all duration-700 hover:scale-105"
                         src="https://images.unsplash.com/photo-1616046229478-9901c5536a45?q=80&w=800&auto=format&fit=crop" />
                </div>
            </div>
        </div>
    </section>

    <!-- Featured Collections Section -->
    <section class="pb-section-gap px-8 md:px-16 bg-surface">
        <div class="container-center">
            <div class="flex justify-between items-end mb-16">
                <div>
                    <span
                    class="text-xs font-sans text-primary uppercase tracking-[0.2em] block mb-stack-sm">اختياراتنا</span>
                    <h2 class="text-4xl md:text-5xl font-serif text-on-surface">مجموعات مختارة</h2>
                </div>
                <a class="text-xs font-sans text-primary border-b border-primary pb-1 hover:opacity-70 transition-opacity"
                   href="/Collections">اكتشف الكل</a>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-12 gap-8 h-auto md:h-[800px]">
                <div class="md:col-span-8 relative group overflow-hidden h-[400px] md:h-full">
                    <img class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
                         src="https://lh3.googleusercontent.com/aida-public/AB6AXuAqPY1D3BVG56Y9sSBF3XbMwKXCJb7xC0GemcqKhbXNJyA5bfm6ATFNpqax0VB7tQhiH0LW7IaoX3avaXxygnpPENx5ejSOF681KCHvj4Zs6jUGBVmiQaCyFhBLl-aGQv_3nvl7zawunJvqt5HPnMDbAy3qe2lZwjkEq8n9WQXc-iCWILi6xqv-2oa_iZaskPhtVa56zAz0fjn9EchXmX8qYL7EuZKL0c4GSFd2K0SJ9j7b5Aha8eERWO2gP2hPcYMrnFGCtsebSzk" />
                    <div
                        class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent flex flex-col justify-end p-12 text-right">
                        <h3 class="text-3xl font-serif text-white mb-2">سلسلة المونوليث</h3>
                        <p class="text-lg font-sans text-white/80">هندسة جريئة تلتقي براحة لا تضاهى.</p>
                    </div>
                </div>
                <div class="md:col-span-4 flex flex-col gap-8 h-full">
                    <div class="h-[300px] md:h-1/2 relative group overflow-hidden">
                        <img class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
                             src="https://lh3.googleusercontent.com/aida-public/AB6AXuDH8O1QmW8VXtezYHcjbjZN84NpEJQq8Xw_QYRNF7gq3ZD7To9iIkdqF2Gjo8LhL2FUjbN9SimL_nJNzCd4ODKQGj3JGfMAOn7kVTkloOhYA9sVTNg1aPUTrQ_7-9qjzOlshjxlqS8GcP_2T9czLjMKh4L2AgK5UxeVKu0UAH59T7lgGQo3LaWZNnOi98a1WTESMbD0oMvV26p9a7RxF9YXVLIj31X1n94Mu7daK_GOSbgSQyzlA0K2wZBkzdUwDk1YP_V_S2Nbd8c" />
                        <div
                            class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent flex flex-col justify-end p-8 text-right">
                            <h3 class="text-2xl font-serif text-white">مجموعة الملاذ</h3>
                        </div>
                    </div>
                    <div class="h-[300px] md:h-1/2 relative group overflow-hidden">
                        <img class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
                             src="https://lh3.googleusercontent.com/aida-public/AB6AXuD9gYqs_eq0mpqGLKQzVVox4KH58IKHxOAHML-EmVIwm4cDiged4Rsh-T6p8C7PUnl4JxD6GNlBRxOziR814dbKcgNe8tZrH_y6PxpXd7t2qsEAUDb8465BIKdfKn2R8SW0J8Z_KKlr6f1KwoLI_YfCIcYX5188eCqdQaCFu9s6H4a2hTbm5t5AsxAbgTo0TaXzSOcMWSjtk5xyN5Sk3nYeNJJsnaZFVQfe1EjJRj2pY0AStHokVM668jgBTbkrDE19dePmQmuGFMM" />
                        <div
                            class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent flex flex-col justify-end p-8 text-right">
                            <h3 class="text-2xl font-serif text-white">أساسيات التميز</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Newsletter / Contact Split -->
    <section class="bg-primary-container/10 py-24 px-8 md:px-16">
        <div class="container-center grid grid-cols-1 md:grid-cols-2 gap-24 items-center">
            <div class="text-right">
                <h2 class="text-4xl font-serif text-on-surface mb-stack-md">ابقَ على اطلاع</h2>
                <p class="text-lg font-sans text-secondary mb-stack-lg max-w-md">
                    انضم إلى قائمتنا البريدية الحصرية للحصول على وصول مبكر للمجموعات الجديدة ودعوات لفعاليات صالات العرض
                    الخاصة.
                </p>
                <div class="flex flex-col gap-4">
                    <div class="border-b border-on-surface py-4 flex items-center flex-row-reverse">
                        <input
                        class="bg-transparent border-none focus:ring-0 w-full font-sans text-sm placeholder:text-secondary/50 text-right"
                        placeholder="بريدك الإلكتروني" type="email" />
                        <button
                        class="material-symbols-outlined text-on-surface transform rotate-180">arrow_forward</button>
                    </div>
                </div>
            </div>
            <div class="bg-on-surface p-12 md:p-16 text-surface text-right">
                <span
                class="text-xs font-sans text-primary-container uppercase tracking-[0.2em] block mb-stack-sm">استشارة</span>
                <h3 class="text-3xl font-serif mb-stack-md">خدمة معمارية خاصة</h3>
                <p class="text-lg font-sans text-surface/70 mb-stack-lg leading-relaxed">
                    تعاون مع كبار المصممين لدينا لتأثيث مساحتك بدقة متناهية. نقدم رعاية شاملة للمشاريع السكنية الراقية.
                </p>
                <button
                    class="text-primary-container font-sans text-sm uppercase tracking-widest border-b border-primary-container pb-1 hover:text-surface hover:border-surface transition-all">احجز
                    استشارة</button>
                </div>
            </div>
        </section>
    </main>
