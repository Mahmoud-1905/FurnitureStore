@using FurnitureStore.Models.UserRoles.Models
@using Microsoft.AspNetCore.Identity;
@inject SignInManager<Users> signInManager;

<div class="flex items-center gap-6">
    @if (signInManager.IsSignedIn(User))
    {
        <div class="flex items-center gap-4">
            <span class="font-sans text-sm text-on-surface/70">أهلاً، @User.Identity?.Name</span>
            <form asp-controller="Account" asp-action="Logout" method="post" class="inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="font-sans text-sm uppercase text-primary hover:text-on-surface transition-colors cursor-pointer">
                    تسجيل الخروج
                </button>
            </form>
        </div>
    }
    else
    {
        <a href="/Account/Login" class="font-sans text-sm uppercase text-on-surface/70 hover:text-primary transition-colors cursor-pointer">
            تسجيل الدخول
        </a>
        <a href="/Account/Register" class="font-sans text-sm uppercase text-primary border border-primary px-4 py-2 hover:bg-primary hover:text-surface transition-all cursor-pointer">
            إنشاء حساب
        </a>
    }
</div>
