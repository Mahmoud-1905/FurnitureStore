@model List<FurnitureStore.Models.Product>

@{
    ViewData["Title"] = "Products";
}

<style>
    body {
        background: #f4f6f9;
        font-family: 'Segoe UI', sans-serif;
    }

    .products-container {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 30px;
        padding: 50px;
    }

    .product-card {
        background: #fff;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 8px 25px rgba(0,0,0,0.08);
        transition: all 0.3s ease;
        position: relative;
    }

        .product-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.15);
        }

    .product-img {
        width: 100%;
        height: 230px;
        object-fit: cover;
        transition: 0.3s;
    }

    .product-card:hover .product-img {
        transform: scale(1.05);
    }

    .product-content {
        padding: 20px;
        text-align: left;
    }

    .product-name {
        font-size: 17px;
        font-weight: 600;
        color: #222;
        margin-bottom: 8px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .product-price {
        font-size: 20px;
        color: #111;
        font-weight: bold;
        margin-bottom: 15px;
    }

    .btn-cart {
        width: 100%;
        padding: 12px;
        border: none;
        border-radius: 12px;
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: white;
        font-weight: bold;
        cursor: pointer;
        transition: 0.3s;
    }

        .btn-cart:hover {
            opacity: 0.9;
        }

    /* Badge */
    .badge {
        position: absolute;
        top: 15px;
        left: 15px;
        background: #ff4757;
        color: white;
        padding: 5px 10px;
        font-size: 12px;
        border-radius: 8px;
    }
</style>

<div class="products-container">
    @foreach (var item in Model)
    {
        <div class="product-card">

            <div class="badge">NEW</div>

            <img src="@Url.Content(item.ImageUrl)" class="product-img" />

            <div class="product-content">
                <div class="product-name">@item.Name</div>
                <div class="product-price">$@item.Price</div>

                <button class="btn-cart">Add to Cart</button>
            </div>
        </div>
    }
</div>
</main>