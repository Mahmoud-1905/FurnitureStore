@{
    ViewBag.Title = "Your Store";
}
@{
    ViewData["Title"] = "Home";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Smart Furniture Store</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        .hero {
            background: url('/images/furniture-bg.jpg') no-repeat center center;
            background-size: cover;
            height: 90vh;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
        }

        .hero h1 {
            font-size: 60px;
            font-weight: bold;
        }

        .product-card img {
            height: 200px;
            object-fit: cover;
        }

        footer {
            background-color: #222;
            color: white;
            padding: 20px 0;
            text-align: center;
        }
    </style>
</head>

<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="#">Smart Furniture</a>

            <button class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#menu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="menu">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="#">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Products</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">About</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Contact</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero">
        <div>
            <h1>Modern Furniture</h1>
            <p>Make your home stylish and comfortable</p>
            <a href="#" class="btn btn-primary btn-lg">Shop Now</a>
        </div>
    </section>

    <!-- Products Section -->
    <div class="container my-5">
        <h2 class="text-center mb-4">Our Products</h2>

        <div class="row">
            <div class="col-md-4">
                <div class="card product-card">
                    <img src="../wwwroot/images/chair.jpeg" class="card-img-top" alt="Chair">
                    <div class="card-body text-center">
                        <h5 class="card-title">Modern Chair</h5>
                        <p>$120</p>
                        <a href="#" class="btn btn-success">Buy</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card product-card">
                    <img src="../wwwroot/images/table.jpg" class="card-img-top" alt="Table">
                    <div class="card-body text-center">
                        <h5 class="card-title">Wooden Table</h5>
                        <p>$250</p>
                        <a href="#" class="btn btn-success">Buy</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card product-card">
                    <img src="../wwwroot/images/sofa.jpg" class="card-img-top" alt="Sofa">
                    <div class="card-body text-center">
                        <h5 class="card-title">Luxury Sofa</h5>
                        <p>$500</p>
                        <a href="#" class="btn btn-success">Buy</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer>
        <p>© 2026 Smart Furniture Store | All Rights Reserved</p>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>