@model FurnitureStore.Models.Product

<style>
    .details-container {
        display: flex;
        gap: 40px;
        padding: 50px;
        align-items: center;
        flex-wrap: wrap;
    }

    .details-img {
        width: 400px;
        border-radius: 20px;
        object-fit: cover;
    }

    .details-content {
        max-width: 500px;
    }

    .details-title {
        font-size: 28px;
        font-weight: bold;
        margin-bottom: 10px;
    }

    .details-price {
        color: #16a34a;
        font-size: 24px;
        font-weight: bold;
        margin: 10px 0;
    }

    .details-desc {
        color: #555;
        margin-bottom: 20px;
        line-height: 1.6;
    }

    .qty-input {
        width: 60px;
        padding: 8px;
        margin-bottom: 20px;
    }

    .btn-cart {
        padding: 12px 30px;
        background: #1f2937;
        color: white;
        border-radius: 10px;
        border: none;
        cursor: pointer;
        font-weight: bold;
    }

        .btn-cart:hover {
            background: #111827;
        }
</style>

<div class="details-container">

    <img src="@Url.Content(Model.ImageUrl)" class="details-img" />

    <div class="details-content">

        <div class="details-title">@Model.Name</div>

        <div class="details-price">₪ @Model.Price</div>

        <div class="details-desc">
            @Model.Description
        </div>

        <form method="get" asp-controller="Cart" asp-action="AddToCart">
            <input type="hidden" name="name"  value="@Model.Name" />
            <input type="hidden" name="price" value="@Model.Price" />
            <input type="hidden" name="image" value="@Model.ImageUrl" />

            <div style="margin-bottom:16px;">
                <label style="font-weight:600;">الكمية:</label>
                <input type="number" name="quantity" value="1" min="1" class="qty-input" />
            </div>

            <button type="submit" class="btn-cart">
                🛒 إضافة للسلة
            </button>
        </form>

        <a asp-controller="Products" asp-action="Index"
           style="display:inline-block;margin-top:14px;color:#2563eb;font-weight:600;text-decoration:none;">
            ← العودة إلى المنتجات
        </a>

    </div>

</div>