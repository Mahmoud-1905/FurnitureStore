@model List<FurnitureStore.Models.Product>
<main>
<h2>إدارة المنتجات</h2>

<a href="/Admin/Create">➕ إضافة منتج</a>

<table border="1" cellpadding="10">
    <tr>
        <th>الاسم</th>
        <th>السعر</th>
        <th>حذف</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.Price</td>
            <td>
                <a href="/Admin/Delete/@item.Id">❌ حذف</a>
            </td>
        </tr>
    }
</table>
</main>